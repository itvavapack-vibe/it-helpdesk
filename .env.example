# GLPI Asset Management
VITE_GLPI_URL=https://your-glpi-host/glpi
VITE_GLPI_APP_TOKEN=
VITE_GLPI_USER_TOKEN=
# ใช้ proxy บน Vercel (แนะนำ) — ไม่ต้องเปิด CORS ที่ GLPI
VITE_USE_GLPI_PROXY=true

# Frontend API (เว้นว่างบน Vercel = เรียก /api บนโดเมนเดียวกัน)
VITE_API_URL=

# Local dev — API แยกพอร์ต 4000
# VITE_API_URL=http://localhost:4000

# MySQL (ใช้ทั้ง local server.js และ Vercel serverless)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=helpdsk_db
DB_USER=root
DB_PASSWORD=
# เปิดเมื่อใช้ cloud MySQL ที่บังคับ SSL
DB_SSL=false

# Local API server only
API_PORT=4000
