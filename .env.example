# GLPI Asset Management
VITE_GLPI_URL=https://your-glpi-host/glpi
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
# Set false for internal/self-signed HTTPS GLPI, true for public trusted certs
GLPI_TLS_REJECT_UNAUTHORIZED=false
# ใช้ proxy บน Vercel (แนะนำ) — ไม่ต้องเปิด CORS ที่ GLPI
VITE_USE_GLPI_PROXY=true

# URL หน้าเว็บสำหรับลิงก์เซ็นปิดงาน / แจ้ง Telegram (LAN)
VITE_PUBLIC_URL=http://192.168.10.213:5173
VITE_WEB_PORT=5173

# Frontend API — เว้นว่าง = LAN auto (http://<host>:4000)
VITE_API_URL=

# LAN / Vercel: proxy GLPI ผ่าน /glpi-proxy (ปิดด้วย false)
VITE_USE_GLPI_PROXY=true

# MySQL (ใช้ทั้ง local server.js และ Vercel serverless)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=helpdsk_db
DB_USER=root
DB_PASSWORD=
# เปิดเมื่อใช้ cloud MySQL ที่บังคับ SSL
DB_SSL=false

# Local API server only
API_PORT=4000

# Telegram notifications (server-side only; do not prefix with VITE_)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
